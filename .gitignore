# Block everything in data/ by default — CARD raw files are NOT CC-BY
# (only the ARO ontology is; the FASTAs, models, and JSON have academic-only terms)
data/*

# But allow the three derived artifacts that ARE built from the CC-BY ontology
!data/aro_index.faiss
!data/aro_bm25.pkl
!data/aro_meta.parquet
!data/.gitkeep
